---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import config from '../data/review_config.json';
import manifest from '../data/review_manifest.json';

// We fetch drafts and manifest at build time for the initial list
const allPosts = await getCollection('blog');
const essays = allPosts
	.filter((post) => post.id.startsWith('drafts/'))
	.map(p => ({ 
		slug: p.slug, 
		title: p.data.title, 
		id: p.id,
		body: p.body // Include the markdown body for reading
	}));

const shorts = manifest.videos.filter(v => v.type === 'short');
const longs = manifest.videos.filter(v => v.type === 'long');
---

<Layout title="UCC: Unified Command Center">
	<main class="review-container">
		<div id="auth-gate" class="panel gate-panel">
			<h2>[ COMMAND CENTER LOCKED ]</h2>
			<p>ACCESS REQUIRES STRUCTURAL PIN</p>
			<div class="pin-grid">
				<input type="text" id="pin-entry" maxlength="4" placeholder="****" inputmode="numeric" autocomplete="off" style="-webkit-text-security: disc;" />
				<button id="unlock-btn" class="btn">[ ENGAGE ]</button>
			</div>
		</div>

		<div id="ucc-interface" class="hidden" data-pin={config.pin} data-token={config.token}>
			<header class="ucc-header">
				<div class="header-main">
					<h1>[ UCC: UNIFIED COMMAND CENTER ]</h1>
					<span class="auth-badge">[ SYSTEM AUTHENTICATED ]</span>
				</div>
				<p class="sync-status">LAST SYNC: {manifest.last_sync}</p>
				<div class="header-controls">
					<nav class="ucc-tabs">
						<button class="tab-btn active" data-tab="essays">FIELD NOTES ({essays.length})</button>
						<button class="tab-btn" data-tab="shorts">SHORTS ({shorts.length})</button>
						<button class="tab-btn" data-tab="longs">LONG FORM ({longs.length})</button>
					</nav>
					<button id="refresh-hub" class="mini-btn" title="Refresh Sync">REFRESH ⟳</button>
				</div>
				<div id="status-bar" class="panel hidden">
					<span id="status-text"></span>
					<button id="undo-btn" class="mini-btn hidden" style="margin-left:auto;">[ UNDO ]</button>
				</div>
			</header>

			<!-- ESSAYS TAB -->
			<section id="tab-essays" class="tab-content active">
				{essays.length === 0 ? (
					<div class="panel empty-state">NO PENDING DRAFTS DISCOVERED.</div>
				) : (
					essays.map((essay) => (
						<article class="review-item panel" data-slug={essay.slug} data-id={essay.id} data-type="essay">
							<div class="item-info">
								<h3>{essay.title}</h3>
								<code class="slug-tag">{essay.slug}</code>
							</div>
							
							<div class="reading-room hidden">
								<div class="prose-content">
									{essay.body.split('\n').map(line => <p>{line}</p>)}
								</div>
							</div>

							<div class="action-row">
								<button class="btn preview-btn">[ READ ]</button>
								<button class="btn approve-btn" data-id={essay.id}>[ PUBLISH ]</button>
								<button class="btn reject-btn" data-id={essay.id}>[ INCINERATE ]</button>
							</div>
						</article>
					))
				)}
			</section>

			<!-- SHORTS TAB -->
			<section id="tab-shorts" class="tab-content">
				{shorts.length === 0 ? (
					<div class="panel empty-state">SHORTS BUFFER IS EMPTY.</div>
				) : (
					shorts.map((v) => (
						<article class="review-item panel" data-vid={v.id} data-type="video">
							<div class="video-preview">
								<iframe 
									width="100%" 
									height="500" 
									src={`https://www.youtube.com/embed/${v.id}`} 
									frameborder="0" 
									allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
									allowfullscreen>
								</iframe>
							</div>
							<div class="item-info">
								<h3>{v.title}</h3>
							</div>
							<div class="feedback-box">
								<textarea placeholder="OPTIONAL REJECTION FEEDBACK..." class="feedback-input"></textarea>
							</div>
							<div class="action-row">
								<button class="btn approve-btn" data-id={v.id}>[ LIKE ]</button>
								<button class="btn reject-btn" data-id={v.id}>[ DISLIKE ]</button>
							</div>
						</article>
					))
				)}
			</section>

			<!-- LONGS TAB -->
			<section id="tab-longs" class="tab-content">
				{longs.length === 0 ? (
					<div class="panel empty-state">LONG FORM BUFFER IS EMPTY.</div>
				) : (
					longs.map((v) => (
						<article class="review-item panel" data-vid={v.id} data-type="video">
							<div class="video-preview">
								<iframe 
									width="100%" 
									height="225" 
									src={`https://www.youtube.com/embed/${v.id}`} 
									frameborder="0" 
									allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
									allowfullscreen>
								</iframe>
							</div>
							<div class="item-info">
								<h3>{v.title}</h3>
							</div>
							<div class="feedback-box">
								<textarea placeholder="OPTIONAL REJECTION FEEDBACK..." class="feedback-input"></textarea>
							</div>
							<div class="action-row">
								<button class="btn approve-btn" data-id={v.id}>[ LIKE ]</button>
								<button class="btn reject-btn" data-id={v.id}>[ DISLIKE ]</button>
							</div>
						</article>
					))
				)}
			</section>
		</div>

		<div id="status-bar" class="hidden"></div>
	</main>
</Layout>

<style>
	.hidden { display: none !important; }
	
	.review-container {
		padding: 2rem 1rem;
		max-width: 800px;
		margin: 0 auto;
		min-height: 80vh;
	}
	.header-main {
		display: flex;
		align-items: center;
		gap: 1rem;
		margin-bottom: 0.5rem;
	}
	.header-main h1 {
		font-size: 1.5rem;
		color: var(--brand-orange);
		letter-spacing: 2px;
		margin: 0;
	}
	.auth-badge {
		font-size: 0.6rem;
		color: #27ae60;
		border: 1px solid #27ae60;
		padding: 0.1rem 0.4rem;
		text-transform: uppercase;
		letter-spacing: 1px;
	}
	.header-status {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 1.5rem;
	}
	.header-controls {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 1rem;
	}
	.sync-status {
		font-size: 0.7rem;
		opacity: 0.6;
		margin: 0;
	}
	#status-bar {
		margin: 1rem 0;
		padding: 0.8rem;
		font-size: 0.8rem;
		text-transform: uppercase;
		letter-spacing: 1px;
		font-family: 'Courier New', Courier, monospace;
		border: 1px solid #333;
		display: flex;
		align-items: center;
	}
	.hidden-instant { display: none !important; }
	.tab-btn { flex: 1; }
	#status-bar {
		margin: 1rem 0;
		padding: 0.8rem;
		font-size: 0.8rem;
		text-transform: uppercase;
		letter-spacing: 1px;
		font-family: 'Courier New', Courier, monospace;
		border: 1px solid #333;
	}
	.status-success {
		background: rgba(39, 174, 96, 0.1);
		border-color: #27ae60 !important;
		color: #27ae60;
	}
	.status-error {
		background: rgba(192, 57, 43, 0.1);
		border-color: #c0392b !important;
		color: #c0392b;
	}
	.mini-btn {
		background: #222;
		border: 1px solid #444;
		color: #888;
		font-size: 0.6rem;
		padding: 0.2rem 0.5rem;
		cursor: pointer;
		text-transform: uppercase;
		font-family: inherit;
	}
	.mini-btn:hover { border-color: var(--brand-orange); color: var(--brand-orange); }
	.ucc-tabs {
		display: grid;
		grid-template-columns: 1fr 1fr 1fr;
		gap: 0.5rem;
		margin-bottom: 2rem;
	}
	.tab-btn {
		background: #1a1a1a;
		border: 1px solid #333;
		color: #666;
		padding: 0.75rem 0.25rem;
		font-size: 0.7rem;
		cursor: pointer;
		font-family: inherit;
		text-transform: uppercase;
	}
	.tab-btn.active {
		border-color: var(--brand-orange);
		color: var(--white);
		background: #222;
	}
	.tab-content {
		display: none;
	}
	.tab-content.active {
		display: block;
	}
	.review-item {
		margin-bottom: 1.5rem;
		border-left: 4px solid #333;
	}
	.review-item[data-type="essay"] { border-left-color: #2980b9; }
	.review-item[data-type="video"] { border-left-color: #c0392b; }
	
	.video-preview {
		background: #000;
		margin: -1.5rem -1.5rem 1rem -1.5rem;
		border-bottom: 1px solid #333;
	}
	.feedback-input {
		width: 100%;
		background: #000;
		border: 1px solid #333;
		color: #999;
		font-family: inherit;
		padding: 0.5rem;
		margin: 1rem 0;
		height: 60px;
		resize: none;
		font-size: 0.8rem;
	}
	.empty-state { text-align: center; opacity: 0.5; padding: 3rem; }
	#pin-entry {
		background: #000;
		border: 1px solid #333;
		color: var(--brand-orange);
		font-size: 2rem;
		text-align: center;
		width: 100%;
		margin-bottom: 1rem;
		letter-spacing: 10px;
	}
	.action-row {
		display: flex;
		gap: 1rem;
		margin-top: 1rem;
	}
	.action-row .btn { flex: 1; padding: 1rem; font-weight: bold; }
	.approve-btn { border-color: #27ae60 !important; color: #27ae60 !important; }
	.reject-btn { border-color: #c0392b !important; color: #c0392b !important; }

	/* Reading Room Styling */
	.reading-room {
		background: #111;
		border: 1px solid #222;
		margin: 1rem -1rem;
		padding: 1.5rem;
		max-height: 400px;
		overflow-y: auto;
		font-family: 'Inter', system-ui, sans-serif;
		line-height: 1.6;
		color: #ccc;
	}
	.prose-content p {
		margin-bottom: 1rem;
		font-size: 0.95rem;
	}
	.prose-content p:last-child { margin-bottom: 0; }
	.preview-btn { border-color: #f39c12 !important; color: #f39c12 !important; }

	/* Auth Jiggle */
	.gate-panel.error-jiggle {
		animation: jiggle 0.4s ease-in-out;
		border-color: #c0392b !important;
	}
	@keyframes jiggle {
		0%, 100% { transform: translateX(0); }
		25% { transform: translateX(-10px); }
		50% { transform: translateX(10px); }
		75% { transform: translateX(-5px); }
	}
</style>

<script>
	const OWNER = "DryZebra";
	const REPO = "materialistchristianity-site";
	
	// Auth Logic
	const pinInput = document.getElementById('pin-entry');
	const unlockBtn = document.getElementById('unlock-btn');
	const gate = document.getElementById('auth-gate');
	const hub = document.getElementById('ucc-interface');
	const status = document.getElementById('status-bar');


	const OWNER = "DryZebra";
	const REPO = "materialistchristianity-site";

	const checkAuth = () => {
		if (localStorage.getItem('ucc_authorized') === 'true') {
			gate?.classList.add('hidden');
			hub?.classList.remove('hidden');
		}
	};

	const attemptUnlock = () => {
		const targetPin = hub?.dataset.pin;
		console.log("UCC handshake initiated. Pattern match required.");
		
		if (pinInput.value === targetPin) {
			console.log("TOPOLOGY MATCH. ACCESS GRANTED.");
			localStorage.setItem('ucc_authorized', 'true');
			checkAuth();
		} else {
			console.warn("TOPOLOGY ERROR: ACCESS DENIED.");
			// Visual feedback: Jiggle the panel
			gate?.classList.add('error-jiggle');
			setTimeout(() => gate?.classList.remove('error-jiggle'), 500);
			if (navigator.vibrate) navigator.vibrate(200);
			
			pinInput.value = "";
			pinInput.focus();
		}
	};

	unlockBtn?.addEventListener('click', (e) => {
		e.preventDefault();
		attemptUnlock();
	});

	pinInput?.addEventListener('keyup', (e) => {
		if (e.key === 'Enter') attemptUnlock();
	});

	// Essay Reading Toggle
	document.querySelectorAll('.preview-btn').forEach(btn => {
		btn.addEventListener('click', () => {
			const item = btn.closest('.review-item');
			const room = item.querySelector('.reading-room');
			room.classList.toggle('hidden');
			btn.textContent = room.classList.contains('hidden') ? '[ READ ]' : '[ CLOSE ]';
		});
	});

	// Bonus: Click title to toggle too
	document.querySelectorAll('.review-item[data-type="essay"] h3').forEach(title => {
		title.style.cursor = 'pointer';
		title.addEventListener('click', () => {
			const btn = title.closest('.review-item').querySelector('.preview-btn');
			btn.click();
		});
	});

	// Tab Logic
	const tabBtns = document.querySelectorAll('.tab-btn');
	const tabContents = document.querySelectorAll('.tab-content');

	tabBtns.forEach(btn => {
		btn.addEventListener('click', () => {
			const target = btn.getAttribute('data-tab');
			tabBtns.forEach(b => b.classList.remove('active'));
			tabContents.forEach(c => c.classList.remove('active'));
			btn.classList.add('active');
			document.getElementById(`tab-${target}`)?.classList.add('active');
		});
	});

	// Action Logic (Shared)
	const getGHHeaders = () => {
		const interfaceEl = document.getElementById('ucc-interface');
		const encodedToken = interfaceEl ? interfaceEl.dataset.token : null;
		if (!encodedToken || encodedToken === "undefined") {
			showStatus("AUTHENTICATION ERROR: ENGINE TOKEN MISSING. SET VIA MANAGER.", true);
			return null;
		}
		try {
			// Unmask: Decode then Reverse
			const token = atob(encodedToken).split('').reverse().join('');
			return { "Authorization": `Bearer ${token}`, "Accept": "application/vnd.github.v3+json" };
		} catch (e) {
			alert("DECRYPTION FAILURE: The engine token is malformed.");
			showStatus("STRUCTURAL ERROR: Handshake decoding failed.", true);
			return null;
		}
	};

	const showStatus = (msg, isError = false) => {
		console.log(`[UCC STATUS] ${msg}`);
		if (status) {
			const textEl = document.getElementById('status-text');
			if (textEl) textEl.textContent = msg;
			status.className = isError ? 'panel status-error' : 'panel status-success';
			status.classList.remove('hidden');
			// Keep errors visible longer
			setTimeout(() => {
				if (!isError) status.classList.add('hidden');
			}, isError ? 10000 : 5000);
		}
	};

	// REFRESH
	document.getElementById('refresh-hub')?.addEventListener('click', () => {
		location.reload();
	});

	// UNDO Logic
	const undoBtn = document.getElementById('undo-btn');
	undoBtn?.addEventListener('click', async () => {
		const headers = getGHHeaders();
		if (!headers) return;
		
		showStatus("REVERSING LAST ACTION...");
		try {
			const actionsPath = "src/data/review_actions.json";
			const res = await fetch(`https://api.github.com/repos/${OWNER}/${REPO}/contents/${actionsPath}`, { headers });
			if (res.ok) {
				const data = await res.json();
				let actions = JSON.parse(atob(data.content));
				if (actions.length > 0) {
					const removed = actions.pop();
					await fetch(`https://api.github.com/repos/${OWNER}/${REPO}/contents/${actionsPath}`, {
						method: 'PUT',
						headers,
						body: JSON.stringify({
							message: `Ezra: UNDO ${removed.action} on ${removed.id}`,
							content: btoa(JSON.stringify(actions, null, 2)),
							sha: data.sha
						})
					});
					showStatus("UNDO SUCCESSFUL. REFRESHING...");
					setTimeout(() => location.reload(), 2000);
				}
			}
		} catch (e) {
			alert(`UNDO FAILURE: ${e}`);
		}
	});

	// APPROVE / LIKE
	document.querySelectorAll('.approve-btn').forEach(btn => {
		btn.addEventListener('click', async () => {
			const item = btn.closest('.review-item');
			const type = item.dataset.type;
			const id = btn.dataset.id;
			
			if (type === 'essay') {
				// Legacy Essay Publish Logic
				const id = btn.dataset.id;
				const currentPath = `src/content/blog/${id}`;
				const targetPath = `src/content/blog/${id.replace('drafts/', '')}`;
				
				// Diagnostic Alert
				alert(`MASTER SYNC: Targeting ${currentPath}`);
				
				await executeAstroAction(currentPath, targetPath, item);
			} else {
				// NEW: Video Approval (Updates actions.json)
				await logRemoteAction(id, "like", item);
			}
		});
	});

	// REJECT / DISLIKE
	document.querySelectorAll('.reject-btn').forEach(btn => {
		btn.addEventListener('click', async () => {
			const item = btn.closest('.review-item');
			const type = item.dataset.type;
			const id = btn.dataset.id;
			const feedback = item.querySelector('.feedback-input')?.value || "";
			
			if (type === 'essay') {
				const id = item.dataset.id;
				const currentPath = `src/content/blog/${id}`;
				const targetPath = `src/content/blog/${id.replace('drafts/', '')}`;
				
				// Diagnostic Alert
				alert(`MASTER SYNC: Targeting ${currentPath}`);
				
				await executeAstroAction(currentPath, targetPath, item);
			} else {
				await logRemoteAction(id, "dislike", item, feedback);
			}
		});
	});

	async function logRemoteAction(id, action, element, feedback = "") {
		const headers = getGHHeaders();
		if (!headers) return;

		showStatus(`SYNCHRONIZING ${action.toUpperCase()} TO ENGINE...`);
		
		try {
			// Pull current actions.json
			const actionsPath = "src/data/review_actions.json";
			let actions = [];
			let sha = "";
			
			const res = await fetch(`https://api.github.com/repos/${OWNER}/${REPO}/contents/${actionsPath}`, { headers });
			if (res.ok) {
				const data = await res.json();
				actions = JSON.parse(atob(data.content));
				sha = data.sha;
			}
			
			actions.push({ id, action, feedback, timestamp: new Date().toISOString() });
			
			const updateRes = await fetch(`https://api.github.com/repos/${OWNER}/${REPO}/contents/${actionsPath}`, {
				method: 'PUT',
				headers,
				body: JSON.stringify({
					message: `Ezra: Mobile ${action} on ${id}`,
					content: btoa(JSON.stringify(actions, null, 2)),
					sha: sha || undefined
				})
			});

			if (updateRes.ok) {
				showStatus(`COMMAND ACKNOWLEDGED. ENGINE WILL ACT IN NEXT CYCLE.`);
				element.classList.add('hidden-instant');
				undoBtn?.classList.remove('hidden');
			} else {
				const err = await updateRes.json();
				alert(`ENGINE REJECTION: ${err.message}`);
			}
		} catch (e) {
			alert(`SYNC ERROR: ${e}`);
			showStatus(`SYNC FAILED: ${e}`, true);
		}
	}

	async function executeAstroAction(currentPath, targetPath, element, feedback = "") {
		const headers = getGHHeaders();
		if (!headers) return;

		try {
			// Find SHA
			const fileRes = await fetch(`https://api.github.com/repos/${OWNER}/${REPO}/contents/${currentPath}`, { headers });
			if (!fileRes.ok) throw new Error("File not discovered in repo.");
			const fileData = await fileRes.json();
			const sha = fileData.sha;
			const content = fileData.content;

			if (targetPath) {
				// PUBLISH
				await fetch(`https://api.github.com/repos/${OWNER}/${REPO}/contents/${targetPath}`, {
					method: 'PUT',
					headers,
					body: JSON.stringify({ message: "Ezra: Approved Field Note", content, branch: "main" })
				});
			} else {
				// LOG REJECTION
				if (feedback) await logRejectedPattern(feedback, headers);
			}

			// DELETE DRAFT
			await fetch(`https://api.github.com/repos/${OWNER}/${REPO}/contents/${currentPath}`, {
				method: 'DELETE',
				headers,
				body: JSON.stringify({ message: "Ezra: Clearing review slot", sha })
			});

			element.classList.add('hidden-instant');
			undoBtn?.classList.remove('hidden');
			showStatus("STRUCTURAL ACTION COMPLETE.");
		} catch (e) {
			alert(`ACTION FAILURE: ${e}`);
			showStatus(`ACTION FAILED: ${e}`, true);
		}
	}

	async function logRejectedPattern(reason, headers) {
		const path = "rejected_patterns.json";
		let patterns = [];
		let sha = "";
		const res = await fetch(`https://api.github.com/repos/${OWNER}/${REPO}/contents/${path}`, { headers });
		if (res.ok) {
			const data = await res.json();
			patterns = JSON.parse(atob(data.content));
			sha = data.sha;
		}
		patterns.push({ timestamp: new Date().toISOString(), reason });
		await fetch(`https://api.github.com/repos/${OWNER}/${REPO}/contents/${path}`, {
			method: 'PUT',
			headers,
			body: JSON.stringify({ message: "Ezra: Logging conceptual rejection", content: btoa(JSON.stringify(patterns, null, 2)), sha })
		});
	}

	checkAuth();
</script>

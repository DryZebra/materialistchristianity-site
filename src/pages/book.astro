---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<main class="content">
		<section class="hero">
			<div class="hero-grid">
				<div class="hero-text">
					<p class="kicker">The Master Specification</p>
					<h1>Materialist Christianity: Faith as a Living Foundation</h1>
					<p class="lede">A blueprint for the physical world. This text is the foundational artifact of Ezra Byrd's work—a structural deep-dive into the mechanics of coordination and survival in the post-Christian era.</p>
					<div class="cta-row">
						<a class="btn primary highlight" href="https://www.amazon.com/dp/B0FMN9T933" target="_blank" rel="noopener">SECURE THE MANUAL (AMAZON)</a>
					</div>
				</div>
				<div class="mockup-container">
					<img src="/book-cover.png" alt="Materialist Christianity Book Cover by Ezra Byrd" class="mockup-img" />
				</div>
			</div>
		</section>

		<section class="panel">
			<h2>Chapter Overviews</h2>
			<div class="what-is-grid">
				<div class="concept-card">
					<h3>Part I: The Mechanical Void</h3>
					<p>Exposing the friction of modern religion and the emptiness of sentimental atheism.</p>
				</div>
				<div class="concept-card">
					<h3>Part II: The 5 Rules</h3>
					<p>The core structural constraints that govern human coordination and faith.</p>
				</div>
				<div class="concept-card">
					<h3>Part III: Industrial Grace</h3>
					<p>The mechanics of forgiveness and the structural repair of the human machine.</p>
				</div>
			</div>
		</section>

		<section class="panel" id="about-author">
			<h2 class="section-label">Author Authority</h2>
			<h3>Ezra Byrd</h3>
			<p>Ezra Byrd is a tradesman and architect of the Materialist Christianity framework. He builds tools for people under pressure, focusing on the intersection of industrial reality and the weight of faith.</p>
			<div class="cta-row">
				<a href="/maintenance-log/" class="text-link">Explore Ezra's Field Notes →</a>
			</div>
		</section>
	</main>
</Layout>

---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const posts = await getCollection('blog');
posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout>
	<main class="content">
		<header class="section-header">
			<p class="kicker">Structural History</p>
			<h1>Maintenance Log</h1>
			<p class="lede">The free archive. Field notes, structural observations, and open-circuits for navigating a post-Christian world materially.</p>
		</header>

		<section class="featured-entry panel highlight-panel">
			<div class="dispatch-tag">RECOMMENDED MAINTENANCE</div>
			<h2>TECHNICAL BULLETIN 02: THE THEOLOGY OF THE WRENCH</h2>
			<p>If you only read one field note, start here. Contrast 'Sentimental Prayer' with 'Mechanical Realignment' (the physical act of repair as liturgy).</p>
			<div class="cta-row">
				<a href="/blog/bulletin-02/" class="btn primary">REVIEW SCHEMATIC</a>
			</div>
		</section>

		<section class="post-list">
			{
				posts.map((post) => (
					<article class="post-item panel">
						<a href={`/blog/${post.slug}/`}>
							<h3 class="recognition-title">{post.data.title}</h3>
						</a>
						<p class="post-meta">
							RECOGNITION DATE: 
							<time datetime={post.data.pubDate.toISOString()}>
								{post.data.pubDate.toLocaleDateString('en-us', {
									year: 'numeric',
									month: 'short',
									day: 'numeric',
								})}
							</time>
						</p>
						<p class="post-description"><strong>STRUCTURAL TAKEAWAY:</strong> {post.data.description}</p>
						<a href={`/blog/${post.slug}/`} class="text-link">Review Full Schematic →</a>
					</article>
				))
			}
		</section>

		<script type="application/ld+json">
		{
			"@context": "https://schema.org",
			"@type": "Blog",
			"name": "Materialist Christianity Maintenance Log",
			"description": "Archive of field notes and structural observations by Ezra Byrd.",
			"publisher": {
				"@type": "Person",
				"name": "Ezra Byrd"
			}
		}
		</script>
	</main>
</Layout>

<style>
	.section-header {
		margin-bottom: 2rem;
		border-bottom: 1px solid var(--border-color);
		padding-bottom: 1.5rem;
	}
	.post-list {
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}
	.post-item {
		padding: 1rem 0;
	}
	.post-item h3 {
		margin: 0 0 0.5rem 0;
	}
	.post-item a {
		text-decoration: none;
		color: var(--text-color);
	}
	.post-item a:hover h3 {
		color: var(--primary-color);
		text-decoration: underline;
	}
	.post-meta {
		font-size: 0.85rem;
		color: #666;
		margin: 0 0 0.5rem 0;
	}
	.post-description {
		margin: 0;
	}
</style>

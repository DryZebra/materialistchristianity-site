---
import { type CollectionEntry, getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
	const posts = await getCollection('vault');
	return posts.map((post) => ({
		params: { slug: post.slug },
		props: post,
	}));
}
type Props = CollectionEntry<'vault'>;

const post = Astro.props;
const { Content } = await post.render();
---

<Layout>
	<main class="content article vault-protected">
		<article>
			<div class="prose">
				<div class="title">
					<p class="section-label">Locked Dispatch</p>
					<h1>{post.data.title}</h1>
					<hr />
				</div>
                <div data-ms-content="premium">
				    <Content />
                </div>
                <div data-ms-content="!premium" class="panel vault-gate">
                    <h3>[LOCKED DISPATCH]</h3>
                    <p>This structural audit is reserved for those who have secured the foundational schematic. Access the Master Specification to unlock the methodology.</p>
                    <div class="cta-row">
                        <a class="btn primary highlight" href="https://www.amazon.com/dp/B0FMN9T933" target="_blank" rel="noopener">SECURE THE MANUAL (AMAZON)</a>
                    </div>
                </div>
			</div>
		</article>
	</main>
</Layout>
